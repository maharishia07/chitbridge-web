{
  "name": "Chit & Bridge — illustration pack (concept)",
  "style": {
    "viewBox": "0 0 480 320",
    "palette": {
      "ink": "#243441", "muted": "#7E8A91",
      "blue": "#3F66A6", "blueLight": "#8FAAD0", "blueBg": "#E9F0F8",
      "gold": "#C08A2E", "goldBg": "#F5ECD6",
      "green": "#3E8A5F", "greenBg": "#E4F0E9",
      "red": "#C2473F", "redBg": "#FBE9E7",
      "panel": "#F7F4EE", "line": "#D9E2E8"
    },
    "rule": "One self-contained SVG per subject. To change a screen's art, edit only that one file."
