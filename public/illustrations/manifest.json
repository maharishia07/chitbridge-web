    { "file": "chit-bridged.svg",    "title": "Chit bridged",    "where": "Onboarding · send-success (two co-held copies)" },
    { "file": "compose-author.svg",  "title": "Compose / author","where": "Compose empty · compose help" },
    { "file": "draft.svg",           "title": "Draft",           "where": "Drafts folder (empty)" },
    { "file": "archive-sunset.svg",  "title": "Archive (sunset)","where": "Archive folder · sunset model" },
    { "file": "priority-sla.svg",    "title": "Priority / SLA",  "where": "Priority badge · delivery / SLA-ISL" },
    { "file": "forward.svg",         "title": "Forward",         "where": "Forward confirmation (new thread)" },
    { "file": "empty-inbox.svg",     "title": "Empty list",      "where": "Any list with no rows yet" },
    { "file": "no-results.svg",      "title": "No results",      "where": "Search / advanced-filter empty" }
  ]
